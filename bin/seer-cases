#!/usr/bin/env python
"""
Runs `scm.cases.seer` use cases against a github-server instance via the RPC client.

Usage:
    bin/seer-cases --repo owner/repo <command> [args...]

Configuration (CLI args override env vars):
    --base-url / SCM_RPC_BASE_URL       Server URL (default: http://127.0.0.1:8080)
    --secret / SCM_RPC_SIGNING_SECRET   HMAC signing secret (default: "secret")
    --org-id                            Organization ID (default: 1)
    --repo / GITHUB_REPOSITORY_NAME     GitHub repository as owner/repo

Commands:
    get-file-content <path> <sha>
    get-commit-patch-for-file <path> <commit_sha>
    get-valid-file-paths <commit_sha> [--max-file-size <bytes>]
    get-git-tree <commit_sha>
    get-commit-history <path> <sha> [--max-commits <n>] [--page <n>] [--since <iso>] [--until <iso>]
"""

import argparse
import datetime as dt
import json
import logging
import pathlib
import sys

from scm.cases import seer
from scm.rpc.client import SourceCodeManager

logger = logging.getLogger(__name__)


def dump(obj):
    logger.info(json.dumps(obj, indent=2, default=str))


def load_credentials() -> dict[str, str]:
    """Load KEY=VALUE pairs from .credentials, skipping blanks and comments."""
    creds: dict[str, str] = {}
    path = pathlib.Path(__file__).resolve().parent.parent / ".credentials"
    if not path.exists():
        return creds
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        value = value.strip()
        if value:
            creds[key.strip()] = value
    return creds


def build_file_tree_string(files: list[dict[str, str]]) -> str:
    return "\n".join(f"  {f['status']}\t{f['path']}" for f in files)


def parse_iso(value: str | None) -> dt.datetime | None:
    if value is None:
        return None
    return dt.datetime.fromisoformat(value)


def main():
    creds = load_credentials()

    parser = argparse.ArgumentParser(description="Seer Use Case Runner")
    parser.add_argument("--base-url", default=None)
    parser.add_argument("--secret", default=None)
    parser.add_argument("--org-id", type=int, default=1)
    parser.add_argument(
        "--repo",
        default=creds.get("GITHUB_REPOSITORY_NAME"),
        required="GITHUB_REPOSITORY_NAME" not in creds,
        help="owner/repo; defaults to GITHUB_REPOSITORY_NAME from .credentials",
    )

    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("get-file-content")
    p.add_argument("path")
    p.add_argument("sha")

    p = sub.add_parser("get-commit-patch-for-file")
    p.add_argument("path")
    p.add_argument("commit_sha")

    p = sub.add_parser("get-valid-file-paths")
    p.add_argument("commit_sha")
    p.add_argument("--max-file-size", type=int, default=1024 * 1024)

    p = sub.add_parser("get-git-tree")
    p.add_argument("commit_sha")

    p = sub.add_parser("get-commit-history")
    p.add_argument("path")
    p.add_argument("sha")
    p.add_argument("--max-commits", type=int, default=10)
    p.add_argument("--page", type=int, default=1)
    p.add_argument("--since", default=None, help="ISO-8601 datetime")
    p.add_argument("--until", default=None, help="ISO-8601 datetime")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    scm = SourceCodeManager.make_from_repository_id(
        args.org_id,
        ("github", args.repo),
        base_url=args.base_url if args.base_url else "http://127.0.0.1:8080",
        signing_secret=args.secret if args.secret else "secret",
    )

    if args.command == "get-file-content":
        content = seer.get_file_content(scm, args.path, args.sha)
        if content is None:
            logger.info("null")
        else:
            sys.stdout.buffer.write(content)
            sys.stdout.buffer.write(b"\n")

    elif args.command == "get-commit-patch-for-file":
        dump(seer.get_commit_patch_for_file(scm, args.path, args.commit_sha))

    elif args.command == "get-valid-file-paths":
        valid, oversized = seer.get_valid_file_paths(scm, args.commit_sha, args.max_file_size)
        dump({"valid": sorted(valid), "oversized": sorted(oversized)})

    elif args.command == "get-git-tree":
        tree_sha, entries = seer.get_git_tree(scm, args.commit_sha)
        dump({"tree_sha": tree_sha, "entries": list(entries)})

    elif args.command == "get-commit-history":
        blocks = seer.get_commit_history(
            scm,
            path=args.path,
            sha=args.sha,
            build_file_tree_string=build_file_tree_string,
            max_commits=args.max_commits,
            page=args.page,
            since=parse_iso(args.since),
            until=parse_iso(args.until),
        )
        for block in blocks:
            logger.info(block)


if __name__ == "__main__":
    logging.basicConfig(level=logging.DEBUG)
    main()
