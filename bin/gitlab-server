#!/usr/bin/env python
"""
Standalone RPC server that proxies requests to a GitLab API instance
using personal/group/project access token authentication.

Usage:
    bin/gitlab-server                          # reads from .credentials
    bin/gitlab-server --access-token glpat-... # CLI overrides

Credentials are loaded from .credentials (KEY=VALUE, one per line) then
overridden by env vars, then by CLI args.

Configuration:
    --access-token / GITLAB_ACCESS_TOKEN     GitLab access token (required, see below)
    --base-url / GITLAB_BASE_URL             GitLab instance URL (default: https://gitlab.com)
    --secret / SCM_RPC_SIGNING_SECRET        HMAC signing secret (default: "secret")
    --host                                   Bind address (default: 127.0.0.1)
    --port                                   Listen port (default: 8080)

Credentials:
    A GitLab access token is required to authenticate API requests.
    You can create a personal access token on https://gitlab.com/-/user_settings/personal_access_tokens.
"""

import argparse
import json
import logging
import os
import pathlib
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer
from typing import Any
from urllib.parse import urlparse

import requests

from scm.providers.gitlab.provider import API_VERSION, GitLabProvider
from scm.rpc.server import RpcServer
from scm.types import Provider, Repository, RepositoryId

logger = logging.getLogger(__name__)


class GitLabApiClient:
    """API client that makes authenticated HTTP requests to the GitLab API."""

    def __init__(self, base_url: str, access_token: str) -> None:
        self.base_url = base_url.rstrip("/")
        self.access_token = access_token

    def request(
        self,
        method: str,
        path: str,
        headers: dict[str, str] | None = None,
        data: dict[str, Any] | None = None,
        params: dict[str, str] | None = None,
        allow_redirects: bool | None = None,
        stream: bool | None = None,
        raw_response: bool = True,
    ) -> requests.Response:
        url = f"{self.base_url}{API_VERSION}{path}"
        req_headers = {"Authorization": f"Bearer {self.access_token}"}
        if headers:
            req_headers.update(headers)

        kwargs: dict[str, Any] = {"headers": req_headers}
        if data is not None:
            kwargs["json"] = data
        if params is not None:
            kwargs["params"] = params
        if allow_redirects is not None:
            kwargs["allow_redirects"] = allow_redirects
        if stream is not None:
            kwargs["stream"] = stream

        return requests.request(method, url, **kwargs)


def make_fetch_repository(base_url: str):
    netloc = urlparse(base_url).netloc

    def fetch_repository(organization_id: int, repository_id: RepositoryId) -> Repository | None:
        if isinstance(repository_id, (list, tuple)):
            provider_name, external_id = repository_id
            return {
                "id": 1,
                "external_id": f"{netloc}:{external_id}",
                "integration_id": 1,
                "is_active": True,
                "name": external_id,
                "organization_id": organization_id,
                "provider_name": provider_name,
            }
        return None

    return fetch_repository


def make_fetch_provider(base_url: str, access_token: str):
    def fetch_provider(organization_id: int, repository: Repository) -> Provider | None:
        client = GitLabApiClient(base_url, access_token)
        return GitLabProvider(
            client=client,
            organization_id=organization_id,
            repository=repository,
        )

    return fetch_provider


class RpcHandler(BaseHTTPRequestHandler):
    server: "RpcHTTPServer"

    def do_GET(self):
        headers = dict(self.headers.items())
        response = self.server.rpc.get(headers)
        self.send_response(response.status_code)
        for k, v in response.headers.items():
            self.send_header(k, v)
        self.end_headers()
        self.wfile.write(response.content)

    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", 0))
        data = self.rfile.read(content_length)
        headers = dict(self.headers.items())

        try:
            response = self.server.rpc.post(data, headers)
        except Exception as exc:
            body = json.dumps({"errors": [{"detail": str(exc)}]}).encode()
            self.send_response(502)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(body)
            return

        self.send_response(response.status_code)
        for k, v in response.headers.items():
            self.send_header(k, v)
        self.end_headers()
        for chunk in response.content:
            self.wfile.write(chunk)

    def log_message(self, format, *args):
        sys.stderr.write(f"[{self.log_date_time_string()}] {format % args}\n")


class RpcHTTPServer(HTTPServer):
    def __init__(self, server_address, handler_class, rpc: RpcServer) -> None:
        self.rpc = rpc
        super().__init__(server_address, handler_class)


def load_credentials() -> dict[str, str]:
    """Load KEY=VALUE pairs from .credentials, skipping blanks and comments."""
    creds: dict[str, str] = {}
    path = pathlib.Path(__file__).resolve().parent.parent / ".credentials"
    if not path.exists():
        return creds
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        value = value.strip()
        if value:
            creds[key.strip()] = value
    return creds


def resolve(key: str, cli_value: str | None, creds: dict[str, str]) -> str | None:
    """CLI arg wins, then env var, then .credentials file."""
    return cli_value or os.environ.get(key) or creds.get(key)


def main():
    parser = argparse.ArgumentParser(description="GitLab RPC Server (Access Token Auth)")
    parser.add_argument("--access-token", default=None)
    parser.add_argument("--base-url", default=None)
    parser.add_argument("--secret", default=None)
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8080)
    args = parser.parse_args()

    creds = load_credentials()

    access_token = resolve("GITLAB_ACCESS_TOKEN", args.access_token, creds)
    base_url = resolve("GITLAB_BASE_URL", args.base_url, creds) or "https://gitlab.com"
    secret = resolve("SCM_RPC_SIGNING_SECRET", args.secret, creds) or "secret"

    if not access_token:
        logger.error("Error: missing required config: GITLAB_ACCESS_TOKEN")
        sys.exit(1)

    rpc = RpcServer(
        secrets=[secret],
        fetch_repository=make_fetch_repository(base_url),
        fetch_provider=make_fetch_provider(base_url, access_token),
        record_count=lambda name, value, tags: None,
        emit_error=lambda e: logger.exception(e),
    )

    server = RpcHTTPServer((args.host, args.port), RpcHandler, rpc)
    logger.debug(f"Listening on {args.host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        logger.debug("\nShutting down.")
        server.server_close()


if __name__ == "__main__":
    logging.basicConfig(level=logging.DEBUG)
    main()
